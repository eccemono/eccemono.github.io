padding: 0;
display: flex;
flex-direction: column;
gap: 0.5rem;
}

.goal-list li {
font-size: 0.9rem;
color: var(--color-text-muted);
padding-left: 1rem;
position: relative;
line-height: 1.5;
}

.goal-list li::before {
content: '\2013';
position: absolute;
left: 0;
color: var(--color-accent);
}

.problems-list {
list-style: none;
padding: 0;
margin-top: 1rem;
display: flex;
flex-direction: column;
gap: 0.75rem;
}

.problems-list li {
font-size: 0.95rem;
color: var(--color-text-muted);
line-height: 1.65;
padding-left: 1.25rem;
position: relative;
}

.problems-list li::before {
content: '\2013';
position: absolute;
left: 0;
color: var(--color-accent);
}

.problems-list strong {
color: var(--color-text);
}

.figure {
margin-top: 1.5rem;
}

.figures-stack {
display: flex;
flex-direction: column;
gap: 2rem;
margin-top: 1.5rem;
}

.figure-img {
width: 100%;
border-radius: 8px;
