letter-spacing: -0.03em;
margin-bottom: 0.6rem;
}

.subtitle {
color: var(--color-text-muted);
font-size: 1.05rem;
margin-bottom: 1rem;
max-width: 620px;
}

.meta-row {
display: flex;
flex-wrap: wrap;
gap: 0.4rem;
margin-top: 0.5rem;
}

.para-gap {
margin-top: 1rem;
}

